rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /nicknames/{nickId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // 프로필: 공개 읽기, 본인 문서만 쓰기
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{uid}/saved/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/watch_history/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/conversations/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /conversations/{convId}/messages/{docId} {
      allow read, write: if request.auth != null;
    }

    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /likes/{uid} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      match /dislikes/{uid} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    match /drama_reviews/{docId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
    match /drama_views/{dramaId} {
      allow read, write: if true;
    }
    match /drama_view_daily/{date} {
      allow read, write: if true;
    }
    match /drama_search_daily_clicks/{date} {
      allow read, write: if true;
    }
    match /drama_search_stats/{docId} {
      allow read, write: if true;
    }
    match /episode_ratings/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    match /episode_reviews/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
  }
}
