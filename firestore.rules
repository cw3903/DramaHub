rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /nicknames/{nickId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // 프로필: 공개 읽기. 본인 전체 수정 + 타인은 followersCount 필드만 변경(팔로우/언팔).
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId
        || (
          request.auth.uid != userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount'])
        )
      );
    }

    match /users/{uid}/saved/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // 다이어리·커스텀 리스트·워치리스트: 공개 프로필이므로 누구나 읽기 가능, 본인만 쓰기.
    match /users/{uid}/watch_history/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/custom_lists/{listId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/watchlist/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/conversations/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid}/following/{targetUid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/followers/{followerUid} {
      allow read: if true;
      allow write: if request.auth != null
        && (request.auth.uid == uid || request.auth.uid == followerUid);
    }

    // 인박스 알림: 본인만 읽기·읽음 처리, 다른 로그인 사용자만 문서 생성(좋아요·댓글 등)
    // create는 필드 검증을 느슨하게 — 클라이언트 맵·서버타임스탬프 조합에서 isRead 등으로 거절되는 경우 방지
    match /users/{uid}/notifications/{docId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null
        && request.auth.uid != uid
        && request.resource.data.type is string
        && request.resource.data.fromUser is string
        && request.resource.data.postId is string
        && request.resource.data.postTitle is string;
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    match /conversations/{convId}/messages/{docId} {
      allow read, write: if request.auth != null;
    }

    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /likes/{uid} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      match /dislikes/{uid} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    match /drama_reviews/{docId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
    match /drama_views/{dramaId} {
      allow read, write: if true;
    }
    match /drama_view_daily/{date} {
      allow read, write: if true;
    }
    match /drama_search_daily_clicks/{date} {
      allow read, write: if true;
    }
    match /drama_search_stats/{docId} {
      allow read, write: if true;
    }
    match /episode_ratings/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    match /episode_reviews/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
      match /thread/{threadId} {
        allow read: if true;
        allow create, update, delete: if request.auth != null;
      }
    }
  }
}
